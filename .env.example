# Copy this file to .env and fill in real values before running docker compose up

# PostgreSQL password (used by both postgres container and back-end connection string)
POSTGRES_PASSWORD=changeme

# JWT signing key — must be at least 32 characters, keep secret
JWT_KEY=change-this-to-a-strong-random-secret-at-least-32-chars

# Admin credentials for the CMS
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# URL the browser uses to reach the API (used at front-end build time)
NEXT_PUBLIC_API_URL=http://localhost:8080

# URL the back-end allows as a CORS origin
FRONTEND_URL=http://localhost:3000
